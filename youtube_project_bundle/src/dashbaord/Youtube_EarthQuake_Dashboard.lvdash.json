{
  "datasets": [
    {
      "name": "d3f3cf20",
      "displayName": "EarthQuake_Detail",
      "queryLines": [
        "select * from silver.earthquake_data_final"
      ],
      "catalog": "youtube_dev",
      "schema": "default"
    },
    {
      "name": "bb9f498e",
      "displayName": "EarthQuake_Type",
      "queryLines": [
        "select count(*) as total_magnitude_bucket\n",
        ",magnitude_bucket from (select CASE\n",
        "  WHEN mag < 2 THEN 'Micro (<2)'\n",
        "  WHEN mag BETWEEN 2 AND 3 THEN 'Minor (2–3)'\n",
        "  WHEN mag BETWEEN 3 AND 4 THEN 'Light (3–4)'\n",
        "  ELSE 'Moderate+ (4+)'\n",
        "END AS magnitude_bucket\n",
        "from silver.earthquake_data )\n",
        "group by magnitude_bucket"
      ],
      "catalog": "youtube_dev",
      "schema": "default"
    },
    {
      "name": "fd540ff7",
      "displayName": "EarthQuake_Country",
      "queryLines": [
        "SELECT \n",
        "  count(*) AS event_count,\n",
        "  -- CASE \n",
        "  --   WHEN size(split(place, ', ')) = 1 THEN split(place, ', ')[0]\n",
        "  --   ELSE split(place, ', ')[1]\n",
        "  -- END AS country\n",
        "  split(place, ', ')[1] as country\n",
        "FROM (\n",
        "  SELECT \n",
        "     time,\n",
        "    title,\n",
        "    mag,\n",
        "    longitude,\n",
        "    place,\n",
        "    latitude\n",
        "  FROM silver.earthquake_data_final\n",
        ")\n",
        "GROUP BY country"
      ],
      "catalog": "youtube_dev",
      "schema": "default"
    }
  ],
